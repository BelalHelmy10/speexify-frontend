{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.2",
    "@sanity/client": "^7.13.0",
    "@sentry/browser": "^10.26.0",
    "@testing-library/dom": "^10.4.1",
    "axios": "^1.16.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.17",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "next-intl": "^4.13.0",
    "pdfjs-dist": "^5.4.394",
    "react": "^19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-calendar": "^6.0.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "puppeteer": "^24.43.1",
    "sass": "^1.93.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "./node_modules/.bin/next dev",
    "build": "./node_modules/.bin/next build --webpack",
    "start": "./node_modules/.bin/next start",
    "lint": "./node_modules/.bin/eslint . --max-warnings=0",
    "lint:fix": "./node_modules/.bin/eslint . --fix",
    "styles:check": "node scripts/checkStyleIsolation.mjs",
    "i18n:check": "node scripts/checkLocales.js",
    "i18n:check:strict": "node scripts/checkLocales.js --strict",
    "qa:responsive": "node scripts/responsiveQa.mjs",
    "qa:public-routes": "node scripts/checkPublicRoutes.mjs --start-server",
    "typecheck": "./node_modules/.bin/tsc --noEmit && ./node_modules/.bin/next typegen .",
    "ci:check": "npm run lint && npm run typecheck && npm run build && npm run qa:public-routes"
  },
  "extends": [
    "next/core-web-vitals"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
